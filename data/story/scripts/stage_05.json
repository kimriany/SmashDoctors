{
  "id": "stage_05",
  "title": "미래의 시간관리국",
  "next_on_win": "ending",
  "boss_class": "entities.Boss_characters.FutureProtagonist",
  "boss_name": "미래의 주인공",
  "stage_json": "data/stages/stage_04.json",
  "script_pre_battle": [
    {"cmd": "bg",      "image": "assets/images/story/bg_ruined_hq.png", "transition": "fade"},
    {"cmd": "dialog",  "speaker": "SYSTEM",  "text": "시간선 붕괴율 100%\n복구 불가"},
    {"cmd": "dialog",  "speaker": "주인공", "text": "대체 무슨 일이 일어난 거지."},
    {"cmd": "show_char","slot": "right", "image": "assets/images/story/char_future_self.png"},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "드디어 왔군."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "8회차의 나."},
    {"cmd": "dialog",  "speaker": "주인공",         "text": "넌 누구지."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "난 네가 될 존재다. 혹은. 이미 되어버린 존재지."},
    {"cmd": "dialog",  "speaker": "주인공",         "text": "네가 이 사태의 원인인가?"},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "아니다. 난 결과일 뿐이다."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "자네는 아직도 사상 변화를 상대의 생각을 바꾸는 능력이라고 믿고 있나?"},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "아니야. 자네는 역사 자체를 수정했지."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "잘못된 결론을 지운 것이 아니다. 그 결론에 도달하는 과정을 시간선에서 삭제한 거야."},
    {"cmd": "dialog",  "speaker": "주인공",         "text": "그렇다면 왜 지금까지는 괜찮았지?"},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "괜찮지 않았어. 단지 눈치채지 못했을 뿐."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "시간은 원래 되돌릴 수 없는 법칙이다. 그런데 우리는. 일곱 번이나 그 법칙을 깨뜨렸지."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "8번째부터는 달랐다. 시간이 널 기억하기 시작했거든."},
    {"cmd": "dialog",  "speaker": "주인공",         "text": "...내가 범인이라는 건가."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "이제야 이해했군."},
    {"cmd": "dialog",  "speaker": "주인공",         "text": "그래도 멈출 수는 없다."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "알고 있다. 나도 같은 선택을 했으니까. 여러 번."},
    {"cmd": "battle_start"}
  ],
  "script_post_battle": [
    {"cmd": "show_char","slot": "right", "image": "assets/images/story/char_future_self_defeat.png"},
    {"cmd": "dialog",  "speaker": "주인공",         "text": "끝이다."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "정말 그렇게 생각하나?"},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "날 죽이면. 또 다른 내가 생긴다."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "날 살리면. 세계는 붕괴한다."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "자. 선택해라."},
    {"cmd": "choice",  "options": [
      {"text": "ETERNITY", "goto": "eternity_end"},
      {"text": "NULL",     "goto": "null_end"}
    ]},
    {"cmd": "label",   "id": "null_end"},
    {"cmd": "dialog",  "speaker": "주인공",         "text": "이제 알겠군. 없어져야 하는 건. 범인이 아니었어. 나였어."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "드디어. 여기까지 왔군."},
    {"cmd": "dialog",  "speaker": "SYSTEM",          "text": "현재 기록\nLOOP #8\n삭제."},
    {"cmd": "bg",      "image": null, "transition": "white_flash"},
    {"cmd": "dialog",  "speaker": "SYSTEM", "text": "시간은 고쳐진 것이 아니라,\n처음부터 고칠 필요가 없었다."},
    {"cmd": "ending",  "type": "null"},
    {"cmd": "label",   "id": "eternity_end"},
    {"cmd": "dialog",  "speaker": "주인공",         "text": "방법이 없다."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "방법은 있었어. 하지만 넌 그걸 선택하지 않았지."},
    {"cmd": "dialog",  "speaker": "주인공",         "text": "난 세계를 지켜야 한다."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "날 죽여도. 원인은 사라지지 않아. 원인은 언제나. 우리였어."},
    {"cmd": "dialog",  "speaker": "미래의 주인공", "text": "다음에도. 같은 선택을 하겠지."},
    {"cmd": "dialog",  "speaker": "SYSTEM",          "text": "시간선 안정화 진행 중\n12% → 38% → 67% → 100%"},
    {"cmd": "dialog",  "speaker": "SYSTEM",          "text": "TIME LOOP #9"},
    {"cmd": "ending",  "type": "eternity"}
  ]
}
