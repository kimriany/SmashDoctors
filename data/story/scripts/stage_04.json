{
  "id": "stage_04",
  "title": "물리 스테이지",
  "next_on_win": "stage_05",
  "boss_class": "entities.Boss_characters.Newton",
  "boss_name": "뉴턴",
  "stage_json": "data/stages/stage_04.json",
  "script_pre_battle": [
    {"cmd": "bg",      "image": "assets/images/story/bg_physics.png", "transition": "fade"},
    {"cmd": "dialog",  "speaker": "SYSTEM",  "text": "중력 이상 감지\n시공간 왜곡 감지\n물리 영역 붕괴 진행 중"},
    {"cmd": "dialog",  "speaker": "주인공", "text": "물리학..."},
    {"cmd": "show_char","slot": "right", "image": "assets/images/story/char_newton.png"},
    {"cmd": "dialog",  "speaker": "뉴턴",   "text": "자네도 보이는가?"},
    {"cmd": "dialog",  "speaker": "뉴턴",   "text": "사과가 떨어지지 않는군."},
    {"cmd": "dialog",  "speaker": "주인공", "text": "중력이 붕괴하고 있다."},
    {"cmd": "dialog",  "speaker": "뉴턴",   "text": "아니. 중력이 아니라. 결과가 붕괴하고 있네."},
    {"cmd": "dialog",  "speaker": "뉴턴",   "text": "이젠 이유보다 결과가 먼저 존재하고 있어."},
    {"cmd": "dialog",  "speaker": "뉴턴",   "text": "원인이 자네 자신일 수도 있는데."},
    {"cmd": "battle_start"}
  ],
  "script_post_battle": [
    {"cmd": "show_char","slot": "right", "image": "assets/images/story/char_newton_defeat.png"},
    {"cmd": "dialog",  "speaker": "주인공", "text": "사상 변화."},
    {"cmd": "hide_char","slot": "right"},
    {"cmd": "show_char","slot": "right", "image": "assets/images/story/char_hawking.png"},
    {"cmd": "dialog",  "speaker": "호킹",   "text": "이상하다고 생각한 적 없나?"},
    {"cmd": "dialog",  "speaker": "호킹",   "text": "왜 항상 네가 이 자리에 있는지."},
    {"cmd": "dialog",  "speaker": "주인공", "text": "난 시간관리국 국장이다."},
    {"cmd": "dialog",  "speaker": "호킹",   "text": "그건 직책이고. 내가 묻는 건 존재 이유다."},
    {"cmd": "dialog",  "speaker": "호킹",   "text": "블랙홀은 정보를 삼킨다."},
    {"cmd": "dialog",  "speaker": "호킹",   "text": "그런데 시간은. 정보를 잊지 않는다."},
    {"cmd": "dialog",  "speaker": "호킹",   "text": "아무리 되돌려도. 흔적은 남는다."},
    {"cmd": "battle_start_2"}
  ],
  "script_post_battle_2": [
    {"cmd": "show_char","slot": "right", "image": "assets/images/story/char_hawking_defeat.png"},
    {"cmd": "dialog",  "speaker": "주인공", "text": "사상 변화."},
    {"cmd": "dialog",  "speaker": "호킹",   "text": "그 능력. 정말 상대를 바꾸는 능력이라고 생각하나?"},
    {"cmd": "dialog",  "speaker": "호킹",   "text": "곧 알게 될 걸세."},
    {"cmd": "hide_char","slot": "right"},
    {"cmd": "show_char","slot": "right", "image": "assets/images/story/char_einstein.png"},
    {"cmd": "dialog",  "speaker": "아인슈타인", "text": "결국 여기까지 왔군."},
    {"cmd": "dialog",  "speaker": "아인슈타인", "text": "지금 무슨 짓을 하고 있는지는 알고 있나?"},
    {"cmd": "dialog",  "speaker": "주인공",     "text": "시간선을 복구하고 있다."},
    {"cmd": "dialog",  "speaker": "아인슈타인", "text": "아니. 자네는 시간선을 망가뜨리고 있네."},
    {"cmd": "dialog",  "speaker": "아인슈타인", "text": "이번이 몇 번째인가?"},
    {"cmd": "dialog",  "speaker": "아인슈타인", "text": "8번째겠지."},
    {"cmd": "choice",  "options": [
      {"text": "스킬 사용",   "goto": "use_skill"},
      {"text": "스킬 미사용", "goto": "no_skill"}
    ]},
    {"cmd": "label",   "id": "no_skill"},
    {"cmd": "dialog",  "speaker": "SYSTEM",     "text": "선택 불가\n패시브 : 평온\n사고 차단 중"},
    {"cmd": "label",   "id": "use_skill"},
    {"cmd": "dialog",  "speaker": "아인슈타인", "text": "자기 자신을 수정한 건가. 그건 정말 최악의 선택이었군."},
    {"cmd": "dialog",  "speaker": "주인공",     "text": "사상 변화."},
    {"cmd": "dialog",  "speaker": "아인슈타인", "text": "그 문을 열어버렸군."},
    {"cmd": "shake"},
    {"cmd": "dialog",  "speaker": "아인슈타인", "text": "이제 만나게 될 걸세. 진짜 범인을."},
    {"cmd": "bg",      "image": null, "transition": "fade_black"},
    {"cmd": "dialog",  "speaker": "SYSTEM", "text": "Location : 최후의 물리 실험실"},
    {"cmd": "end"}
  ]
}
